    padding: 1.5rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.6;
  }

  .cookie-table th {
    background: #ececec;
    font-weight: 700;
  }

  .cookie-table tbody tr {
    transition: background-color 0.3s ease;
  }

  .cookie-table tbody tr:hover {
    background-color: #e0e0e0;
  }

  .row-even{
background-color: rgb(255, 255, 255);
  }

  .row-odd{
background-color: rgb(235, 235, 235);
  }

  /* Mobile */
