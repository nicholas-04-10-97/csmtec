---
import logo from "../../assets/LogoWhite.png"

import Arrowdown from "/public/icons/arrowDOWNwhite.png";
---

<header id="site-header">
  <div class="container">

    <!-- Logo -->
    <a href="/" class="logo">
      <img src={logo.src} alt="CSM Logo" />
    </a>

    <!-- Hamburger Button -->
    <button class="menu-toggle" id="menu-toggle" aria-label="Abrir Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- Navigation -->
    <nav id="mobile-menu">
      <ul class="nav-links">
        <li><a href="/#about">SOBRE A CSM</a></li>
        <li><a href="/#services">SERVIÇOS</a></li>
        <li><a href="/#resources">RECURSOS</a></li>

        <!-- Dropdown -->
        <li class="dropdown">
          <a class="dropdown-btn">
            CONTATO<img src={Arrowdown.src} alt="Seta para baixo" style="width: 12px; margin-left: 4px;" />
          </a>

          <ul class="submenu">
            <li><a href="/fale-conosco">Fale Conosco</a></li>
            <li><a href="/seja-um-colaborador">Seja um colaborador</a></li>
          </ul>
        </li>

        <li><a href="/conformidade">CONFORMIDADE</a></li>
      </ul>
    </nav>

  </div>
</header>


<script>
  const header = document.getElementById("site-header");
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const dropdownBtn = document.querySelector(".dropdown-btn");
  const dropdown = document.querySelector(".dropdown");

  // Header background on scroll
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
    }
  });

  // Mobile menu
  menuToggle.addEventListener("click", () => {
    mobileMenu.classList.toggle("active");
    menuToggle.classList.toggle("active");
  });

  // Mobile dropdown
  dropdownBtn.addEventListener("click", () => {
    dropdown.classList.toggle("active");
  });
</script>

<style>
  /* HEADER */
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;

    z-index: 1000;

    background-color: transparent;

    transition:
      background-color 0.35s ease,
      box-shadow 0.35s ease;

    padding: 0.5rem 0;
  }

  #site-header.scrolled {
    background-color: #071b34;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.25);
  }

  /* CONTAINER */
  .container {
    width: min(1200px, 92%);
    margin: 0 auto;

    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* LOGO */
  .logo img {
    height: 58px;
    display: block;
  }

  /* NAVIGATION */
  nav {
    display: flex;
  }

  .nav-links {
    list-style: none;

    display: flex;
    align-items: center;
    gap: 2rem;

    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
  }

  .nav-links li {
    position: relative;
  }

  .nav-links a,
  .dropdown-btn {
    color: white;
    text-decoration: none;

    font-size: 0.85rem;
    font-weight: 500;

    background: none;
    border: none;
    cursor: pointer;

    transition: color 0.3s ease;
    font-family: Arial, sans-serif;

  }


  .nav-links a:hover,
  .dropdown-btn:hover {
    text-decoration: underline;
  }


  /* SUBMENU */
  .submenu {
    position: absolute;
    top: 140%;
    left: 0;

    min-width: 190px;

    background: #ffffff;

    padding: 0;
    list-style: none;

    opacity: 0;
    visibility: hidden;

    transform: translateY(10px);

    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s ease;

    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
  }

  .submenu a {
    display: block;
    padding: 1rem 0 1rem 1rem;
    border: #ffffff 1px solid;
    color: rgb(0, 0, 0);
    font-size: 0.95rem;
  }

.submenu a:hover {
  background-color: #053167;
  color: #ffffff;
  border: #b2b2b2 1px solid;
  text-decoration: none;
}

  /* Desktop dropdown */
  .dropdown:hover .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* HAMBURGER */
  .menu-toggle {
    display: none;

    flex-direction: column;
    justify-content: center;
    gap: 5px;

    width: 42px;
    height: 42px;

    background: none;
    border: none;

    cursor: pointer;
  }

  .menu-toggle span {
    width: 100%;
    height: 3px;

    background: white;
    border-radius: 999px;

    transition: 0.3s ease;
  }



  /* MOBILE */
  @media (max-width: 768px) {

      .logo img {
    height: 36px;
    padding: 6px 0;

  }

    .menu-toggle {
      display: flex;
    }

    nav {
      position: absolute;

      top: 100%;
      left: 0;

      width: 100%;

      background: #071b34;

      overflow: hidden;

      max-height: 0;

      transition: max-height 0.4s ease;
    }

    nav.active {
      max-height: 600px;
    }

    .nav-links {
      flex-direction: column;
      align-items: flex-start;

      gap: 0;

      padding: 1rem 5%;
    }

    .nav-links li {
      width: 100%;
    }

    .nav-links a,
    .dropdown-btn {
      display: block;
      width: 100%;

      padding: 1rem 0;
    }

    /* Mobile submenu */
    .submenu {
      position: static;

      opacity: 1;
      visibility: visible;

      transform: none;

      background: transparent;
      box-shadow: none;

      max-height: 0;
      overflow: hidden;

      padding: 0;

      transition: max-height 0.3s ease;
    }

    .dropdown.active .submenu {
      max-height: 200px;
    }

    .submenu a {
      padding-left: 1rem;
      color: #c9d8ea;
      border: none;
    }

    /* Disable hover dropdown on mobile */
    .dropdown:hover .submenu {
      transform: none;
    }
  }
</style>