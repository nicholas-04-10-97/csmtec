---
import logo from "../../assets/LogoWhite.png"

import Building from "/public/icons/building.png";
import Location from "/public/icons/location.png";
import Mail from "/public/icons/mail.png";
import Phone from "/public/icons/phonewhite.png";
---

<footer class="footer">
<div class="footer-barrier"></div>

  <div class="footer-overlay"></div>

  <div class="footer-container">

    <!-- LEFT -->
    <div class="footer-column footer-brand">
      <img src={logo.src} alt="CSM Logo" class="footer-logo" />

      <p>
        Na CSM Tec, conectamos inovação e tecnologia para
        transformar ideias em soluções reais. Construindo
        um futuro melhor, juntos.
      </p>
    </div>

    <!-- CENTER -->
    <div class="footer-column">
      <h3>Endereço</h3>

      <div class="footer-item">
		<img src={Building.src} alt="Inovação" />
        <span>Edifício Empresarial Alto do Parque</span>
      </div>

      <div class="footer-item">
        <img src={Location.src} alt="Inovação" />
        <span>
          Rua Professor Leopoldo Amaral 366, Pavimento 1001,
          Sala 09 e 10, CEP: 41.830-494, Pituba, Salvador-BA
        </span>
      </div>

      <div class="footer-item">
        <img src={Mail.src} alt="Inovação" />
        <span><a href="mailto:contato@csmtec.com.br">contato@csmtec.com.br</a></span>
      </div>

      <div class="footer-item">
        <img src={Phone.src} alt="Inovação" />
        <a href="tel:+557126261201">+55 (71) 2626-1201</a>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="footer-column">
      <h3>Outros Links</h3>

      <ul class="footer-links">
        <li><a href="/conformidade">Conformidade</a></li>
        <li><a href="/politica-de-cookies">Política de Cookies</a></li>
        <li><a href="/politica-de-privacidade">Política de Privacidade</a></li>
        <li><a href="/termos">Termos de Uso</a></li>
      </ul>
    </div>

  </div>

  <!-- BOTTOM -->
  <div class="footer-bottom">
    © 2025 CSM Tec. Transformando tecnologia em soluções.
    Todos os direitos reservados.
  </div>
</footer>

<style>

.footer {
  position: relative;

  background:
    linear-gradient(
      35deg,
      var(--primary-black) 0%,
      var(--primary-blue) 100%
    );

  color: white;

  overflow: hidden;

}

.footer-overlay {
  position: absolute;
  inset: 0;

  background:
    radial-gradient(
      circle at top right,
      rgba(255,255,255,0.08),
      transparent 35%
    );

  pointer-events: none;
}

.footer-container {
  max-width: 75rem;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1fr 1.2fr 0.8fr;

  gap: 2rem;

  position: relative;
  z-index: 1;
}

.footer-column h3 {
  font-size: 1.25rem;
  font-weight: 700;

  margin-bottom: 1rem;
}

.footer-brand p {
  margin-top: 2rem;

  line-height: 1.8;
  font-size: 1.05rem;

  max-width: 420px;

  color: rgba(255,255,255,0.9);
}

.footer-logo {
  width: 160px;
  display: block;
}

.footer-item {
  display: flex;
  align-items: flex-start;

  gap: 1rem;

  margin-bottom: 0.8rem;

  line-height: 1.6;
}

.footer-item svg {
  min-width: 18px;
  margin-top: 4px;
}

.footer-item img {
  width: 18px;
  height: 18px;
  margin-top: 5px;
}

.footer-item a {
  color: rgba(255,255,255,0.92);

  text-decoration: none;

  transition:
    color 0.3s ease,
    transform 0.3s ease;

  display: inline-block;
}
.footer-links {
  list-style: none;

  padding: 0;
  margin: 0;
}

.footer-links li {
  margin-bottom: 1.4rem;
}

.footer-links a {
  color: rgba(255,255,255,0.92);

  text-decoration: none;

  transition:
    color 0.3s ease,
    transform 0.3s ease;

  display: inline-block;
}

.footer-links a:hover {
  color: white;
  transform: translateX(5px);
}

.footer-bottom {
  text-align: center;

  padding:
    2rem 1rem 2rem;

  margin-top: 2rem;

  font-size: 0.95rem;

  color: rgba(255,255,255,0.8);

  position: relative;
  z-index: 1;
  border-top: var(--primary-blue) 1px solid;
}

.footer-barrier {
    height: 5rem;
    background-color: rgb(255, 255, 255);
    border-radius: 0px 0px 60px 60px;
      margin-bottom: 5rem;

}

/* =========================
   TABLET
========================= */
@media (max-width: 1024px) {

  .footer-container {
    width: 90%;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .footer-brand {
    text-align: center;
    align-items: center;
  }

  .footer-logo {
    margin: 0 auto;
  }

  .footer-brand p {
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .footer-column {
    width: 100%;
  }
}


/* =========================
   MOBILE
========================= */
@media (max-width: 768px) {

  .footer-container {
    width: 92%;
    gap: 2.5rem;
  }

  .footer-column {
    text-align: center;
  }

  .footer-column h3 {
    margin-bottom: 1.5rem;
  }

  .footer-item {
    justify-content: center;
    text-align: left;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .footer-links li {
    margin-bottom: 1rem;
  }

  .footer-links a {
    font-size: 1rem;
  }

  .footer-bottom {
    margin-top: 1.5rem;
    padding: 1.5rem 1rem;
    line-height: 1.6;
  }

  .footer-barrier {
    height: 3rem;
    margin-bottom: 3rem;
    border-radius: 0 0 40px 40px;
  }
}


/* =========================
   SMALL MOBILE
========================= */
@media (max-width: 480px) {

  .footer-container {
    width: 95%;
  }

  .footer-logo {
    width: 140px;
  }

  .footer-brand p {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .footer-item {
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .footer-item img {
    width: 16px;
    height: 16px;
  }

  .footer-column h3 {
    font-size: 1.2rem;
  }

  .footer-links a {
    font-size: 0.95rem;
  }

  .footer-bottom {
    font-size: 0.8rem;
  }
}

</style>