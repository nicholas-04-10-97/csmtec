---
// Example links
const phoneNumber = "5571999999999";
import Phone from "/public/icons/phone.png";
import PhoneHover from "/public/icons/phonewhite.png";
import ArrowUp from "/public/icons/arrowUP.png";
import ArrowupHover from "/public/icons/arrowUPwhite.png";

---
<div class="floating-buttons">
  <!-- Phone Button -->
  <a    href={`https://wa.me/${phoneNumber}`} class="float-btn phone-btn" target="_blank">

<div class="icon-wrapper">
  <img class="icon-default" src={Phone.src} alt="CALL" />
  <img class="icon-hover" src={PhoneHover.src} alt="CALL" />
</div>

  </a>

  <!-- Back To Top Button -->
  <button id="topButton" class="float-btn top-btn">

<div class="icon-wrapper">
  <img class="icon-default" src={ArrowUp.src} alt="UP" />
  <img class="icon-hover" src={ArrowupHover.src} alt="UP" />
</div>  

</button>
</div>

<script>
  const topButton = document.getElementById("topButton");

  function checkScroll() {
    const scrollPosition = window.scrollY + window.innerHeight;
    const pageHeight = document.documentElement.scrollHeight;

    // mostrar quando estiver baixo o suficiente para o botão aparecer
    if (scrollPosition >= pageHeight - 300) {
      topButton.classList.add("show");
    } else {
      topButton.classList.remove("show");
    }
  }

  window.addEventListener("scroll", checkScroll);

  topButton.addEventListener("click", () => {
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  });

  checkScroll();
</script>

<style>
  .floating-buttons {
    position: fixed;
    right: 24px;
    bottom: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    z-index: 9999;
  }

  .float-btn {
    width: 60px;
    height: 60px;
    border: none;
    border-radius: 6px;
    font-size: 28px;
    cursor: pointer;

    display: flex;
    align-items: center;
    justify-content: center;

    text-decoration: none;

    transition:
      transform 0.35s ease,
      opacity 0.35s ease,
      background-color 0.3s ease;
  }

  .phone-btn {
    color: white;
border: 2px solid #6085ff; 
 }

  .phone-btn:hover {
    background: #6085ff;
  }

  .top-btn {
border: 2px solid #6085ff; 
    color: white;
    background: transparent;

    opacity: 0;
    transform: translateY(100px);
    pointer-events: none;
  }

  .top-btn.show {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .top-btn:hover {
    background: #6085ff;
  }


  .icon-wrapper {
  position: relative;
  width: 40px;
  height: 40px;
}

.icon-wrapper img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  transition: opacity 0.3s ease;
}

.icon-hover {
  opacity: 0;
}

.float-btn:hover .icon-hover {
  opacity: 1;
}



</style>