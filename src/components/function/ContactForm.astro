---
const {
  buttonText = "Enviar",
  action = "#"
} = Astro.props;
---

<form class="contact-form" action={action} method="POST">
  <div class="form-row">
    <input
      type="text"
      name="name"
      placeholder="Nome"
      required
    />

    <input
      type="email"
      name="email"
      placeholder="E-mail"
      required
    />
  </div>

  <textarea
    name="message"
    placeholder="Mensagem"
    required
  ></textarea>

  <button type="submit">
    {buttonText}
  </button>
</form>

<style>
  .contact-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-row {
    display: flex;
    gap: 1.5rem;
  }

  .form-row input {
    flex: 1;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 1.4rem;
    border: 1px solid #cfcfcf;
    border-radius: 4px;
    background: #f5f5f5;
    font-size: 1.1rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.3s ease;
    box-sizing: border-box;
  }

  .contact-form textarea {
    min-height: 260px;
    resize: vertical;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: #2f4693;
  }

  .contact-form button {
    width: 100%;
    padding: 1.5rem;
    border: none;
    border-radius: 12px;
    background: #2f4693;
    color: white;
    font-size: 1.8rem;
    cursor: pointer;
    transition:
      background 0.3s ease,
      transform 0.2s ease;
  }

  .contact-form button:hover {
    background: #24397a;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .form-row {
      flex-direction: column;
    }

    .contact-form button {
      font-size: 1.4rem;
    }
  }
</style>